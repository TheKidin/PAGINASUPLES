@model IEnumerable<PIA.Models.ItemCarrito>

@{
    ViewData["Title"] = "Mi Carrito";
    // Mágia: Sumamos el Precio x Cantidad de todo lo que haya en la caja
    decimal total = Model?.Sum(item => item.Cantidad * item.Variante.Producto.Precio) ?? 0;
}

<div class="container mt-5 pt-4 mb-5">
    <h2 class="fw-black text-uppercase italic mb-4"><i class="bi bi-cart3 text-danger"></i> Mi Carrito de Compras</h2>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            <div class="col-md-8 mb-4 mb-md-0">
                <div class="card border-0 shadow-sm rounded-1">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col" class="ps-4 text-muted small text-uppercase">Producto</th>
                                        <th scope="col" class="text-muted small text-uppercase">Precio</th>
                                        <th scope="col" class="text-muted small text-uppercase">Cantidad</th>
                                        <th scope="col" class="text-muted small text-uppercase">Subtotal</th>
                                        <th scope="col"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <img src="@(string.IsNullOrEmpty(item.Variante.Producto.ImagenUrl) ? "https://images.unsplash.com/photo-1593095191071-82b63de74e17?w=100" : item.Variante.Producto.ImagenUrl)" class="rounded border me-3 bg-white" style="width: 60px; height: 60px; object-fit: contain;" alt="@item.Variante.Producto.Nombre">
                                                    <div>
                                                        <h6 class="mb-0 fw-bold text-uppercase" style="font-size: 0.9rem;">@item.Variante.Producto.Nombre</h6>
                                                        <span class="badge bg-dark mt-1">@item.Variante.Sabor</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="fw-semibold text-secondary">$@item.Variante.Producto.Precio.ToString("N2")</td>
                                            <td>
                                                <span class="badge border border-secondary text-dark fs-6 rounded-1 px-3 py-2 bg-light">@item.Cantidad</span>
                                            </td>
                                            <td class="fw-bold text-danger">$@((item.Cantidad * item.Variante.Producto.Precio).ToString("N2"))</td>
                                            <td class="pe-4 text-end">
                                                <button class="btn btn-sm btn-outline-danger shadow-sm"><i class="bi bi-trash-fill"></i></button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-1 bg-light">
                    <div class="card-body p-4">
                        <h5 class="fw-bold text-uppercase mb-4 tracking-wider">Resumen del Pedido</h5>
                        
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted fw-semibold">Subtotal</span>
                            <span class="fw-bold">$@total.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted fw-semibold">Envío</span>
                            <span class="text-success fw-bold"><i class="bi bi-truck"></i> Gratis</span>
                        </div>
                        
                        <hr class="border-secondary opacity-25 mb-4">
                        
                        <div class="d-flex justify-content-between mb-4 align-items-center">
                            <span class="fw-bold text-uppercase">Total</span>
                            <span class="text-danger fw-black fs-3">$@total.ToString("N2")</span>
                        </div>

                        <button class="btn btn-danger btn-lg w-100 fw-bold text-uppercase rounded-1 shadow-sm py-3" style="letter-spacing: 1px;">
                            Proceder al Pago <i class="bi bi-caret-right-fill ms-1"></i>
                        </button>
                        <div class="text-center mt-3">
                            <small class="text-muted fw-semibold"><i class="bi bi-shield-lock-fill text-success"></i> Pago 100% encriptado y seguro</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 my-5">
            <i class="bi bi-cart-x text-muted opacity-50" style="font-size: 5rem;"></i>
            <h3 class="fw-bold text-uppercase mt-4">Tu carrito está vacío</h3>
            <p class="text-muted">¡Aún no has agregado ningún suplemento para romper tus récords!</p>
            <a asp-controller="Home" asp-action="Catalogo" class="btn btn-dark px-5 py-3 text-uppercase fw-bold mt-3 shadow-sm rounded-1">Ir de Compras</a>
        </div>
    }
</div>