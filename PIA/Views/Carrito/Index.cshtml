@using System.Linq
@model IEnumerable<PIA.Models.ItemCarrito>

@{
    ViewData["Title"] = "Tu Arsenal";
    decimal totalEstimado = 0;
}

<div class="container mt-5 pt-5 mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-black text-uppercase italic mb-0" style="color: var(--text-main); letter-spacing: 2px;">Tu Arsenal</h2>
            <p class="text-danger fw-bold small text-uppercase mb-0" style="letter-spacing: 1px;">STATUS: REVISIÓN DE INVENTARIO</p>
        </div>
        <a asp-controller="Home" asp-action="Catalogo" class="btn btn-outline-light btn-sm rounded-0 fw-bold text-uppercase" style="letter-spacing: 1px;">
            <i class="bi bi-arrow-left me-2"></i> Seguir Explorando
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="table-responsive" style="border: 1px solid var(--border-color); background-color: var(--surface-dark);">
                <table class="table table-dark table-borderless table-hover mb-0 align-middle">
                    <thead style="border-bottom: 2px solid var(--accent-color);">
                        <tr class="text-uppercase small" style="letter-spacing: 1px; color: var(--text-muted);">
                            <th scope="col" class="py-3 ps-4">Suplemento</th>
                            <th scope="col" class="py-3 text-center">Precio</th>
                            <th scope="col" class="py-3 text-center">Cantidad</th>
                            <th scope="col" class="py-3 text-center">Subtotal</th>
                            <th scope="col" class="py-3 text-center">Remover</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                // Extraemos el precio del producto a través de la variante
                                decimal precioUnitario = item.Variante?.Producto?.Precio ?? 0;
                                totalEstimado += (precioUnitario * item.Cantidad);

                                <tr>
                                    <td class="py-4 ps-4">
                                        <div class="d-flex align-items-center">
                                            <div style="width: 60px; height: 60px; background-color: #141414; border: 1px solid var(--border-color);" class="d-flex justify-content-center align-items-center p-1 me-3">
                                                @if (item.Variante?.Producto == null || string.IsNullOrEmpty(item.Variante.Producto.ImagenUrl))
                                                {
                                                    <i class="bi bi-box-seam fs-3 text-secondary"></i>
                                                }
                                                else
                                                {
                                                    <img src="@item.Variante.Producto.ImagenUrl" class="img-fluid" style="object-fit: contain; max-height: 100%;" />
                                                }
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fw-bold text-uppercase" style="color: var(--text-main); letter-spacing: 1px;">
                                                    @(item.Variante?.Producto?.Nombre ?? "Suplemento Desconocido")
                                                </h6>
                                                <small style="color: var(--text-muted);">Sabor: @(item.Variante?.Sabor ?? "N/A")</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-4 text-center fw-bold text-white">$@precioUnitario.ToString("N2")</td>
                                    <td class="py-4 text-center">
                                        <span class="badge bg-dark border border-secondary px-3 py-2 rounded-0 fs-6">@item.Cantidad</span>
                                    </td>
                                    <td class="py-4 text-center text-danger fw-bold">$@((precioUnitario * item.Cantidad).ToString("N2"))</td>
                                    <td class="py-4 text-center">
                                        <form asp-action="Eliminar" asp-controller="Carrito" method="post">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-link text-muted hover-danger p-0" title="Remover del arsenal">
                                                <i class="bi bi-trash3-fill fs-5"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <i class="bi bi-cart-x text-muted mb-3" style="font-size: 3rem;"></i>
                                    <h5 class="fw-bold text-uppercase text-muted">Tu arsenal está vacío</h5>
                                    <a asp-controller="Home" asp-action="Catalogo" class="btn btn-danger btn-sm rounded-0 mt-3 fw-bold text-uppercase">Ir al catálogo</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="p-4" style="border: 1px solid var(--border-color); background-color: var(--surface-dark);">
                <h5 class="fw-black text-uppercase italic mb-4" style="color: var(--text-main); letter-spacing: 1px; border-bottom: 1px solid #333; padding-bottom: 15px;">
                    Resumen Táctico
                </h5>
                
                <div class="d-flex justify-content-between mb-3 text-uppercase small fw-bold" style="color: var(--text-muted); letter-spacing: 1px;">
                    <span>Subtotal</span>
                    <span class="text-white">$@totalEstimado.ToString("N2")</span>
                </div>
                
                <div class="d-flex justify-content-between mb-4 text-uppercase small fw-bold" style="color: var(--text-muted); letter-spacing: 1px;">
                    <span>Envío</span>
                    <span class="text-danger">Por Calcular</span>
                </div>
                
                <div class="d-flex justify-content-between mb-4 pb-3" style="border-bottom: 1px solid #333;">
                    <span class="fw-bold text-uppercase" style="color: var(--text-main); letter-spacing: 1px;">Total Estimado</span>
                    <span class="fw-black text-danger fs-5">$@totalEstimado.ToString("N2")</span>
                </div>

                <button class="btn btn-danger btn-lg rounded-0 w-100 fw-black py-3 text-uppercase btn-cart-premium" style="letter-spacing: 2px;" @(totalEstimado == 0 ? "disabled" : "")>
                    <i class="bi bi-shield-lock-fill me-2"></i> PROCEDER AL PAGO
                </button>
            </div>
        </div>
    </div>
</div>