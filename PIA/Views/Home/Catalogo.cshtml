@{
    ViewData["Title"] = "Catálogo";
}

<div class="container mt-5 mb-5 pt-4">
    
    <div class="text-center mb-5">
        <h2 class="fw-black text-uppercase italic section-title" style="letter-spacing: 2px; color: var(--text-main);">Inventario</h2>
        <div class="underline mx-auto mt-3"></div>
    </div>

    <div class="row g-3">
        
        <div class="col-6 col-md-3">
            <a asp-action="Aminoacidos" class="category-card" style="border: 1px solid var(--border-color);">
                <img src="/imagenes/aminopia.png" class="img-fluid" alt="Aminoácidos" style="opacity: 0.85; background-color: #141414;">
                
                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-end justify-content-center pb-4" style="background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, transparent 100%); z-index: 2;">
                    <span class="text-white fw-black text-uppercase" style="letter-spacing: 2px; font-size: 0.9rem; border-bottom: 2px solid var(--accent-color); padding-bottom: 4px;">Aminoácidos</span>
                </div>
            </a>
        </div>

        <div class="col-6 col-md-3">
            <a asp-action="Proteinas" class="category-card" style="border: 1px solid var(--border-color);">
                <img src="~/imagenes/gold-standard-whey.jpg" class="img-fluid" alt="Proteínas" style="opacity: 0.85; background-color: #141414;">
                
                    <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-end justify-content-center pb-4" style="background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, transparent 100%); z-index: 2;">
                        <span class="text-white fw-black text-uppercase" style="letter-spacing: 2px; font-size: 0.9rem; border-bottom: 2px solid var(--accent-color); padding-bottom: 4px;">Proteínas</span>
                    </div>
                </a>
            </div>

            <div class="col-6 col-md-3">
                <a asp-action="Creatinas" class="category-card" style="border: 1px solid var(--border-color);">
                    <img src="~/imagenes/creatinaDragon200.png" class="img-fluid" alt="Creatinas" style="opacity: 0.85; background-color: #141414;">
                
                        <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-end justify-content-center pb-4" style="background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, transparent 100%); z-index: 2;">
                            <span class="text-white fw-black text-uppercase" style="letter-spacing: 2px; font-size: 0.9rem; border-bottom: 2px solid var(--accent-color); padding-bottom: 4px;">Creatinas</span>
                        </div>
                    </a>
                </div>
        
                <div class="col-6 col-md-3">
                    <a asp-action="PreWorkouts" class="category-card" style="border: 1px solid var(--border-color);">
                        <img src="~/imagenes/prefresaK.png" class="img-fluid" alt="Pre-Workouts" style="opacity: 0.85; background-color: #141414;">
                
                            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-end justify-content-center pb-4" style="background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, transparent 100%); z-index: 2;">
                                <span class="text-white fw-black text-uppercase" style="letter-spacing: 2px; font-size: 0.9rem; border-bottom: 2px solid var(--accent-color); padding-bottom: 4px;">Pre-Entrenos</span>
                            </div>
                        </a>
                    </div>
        
                </div>
            </div>      