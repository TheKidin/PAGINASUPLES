@model PIA.Models.Producto

@{
    ViewData["Title"] = Model.Nombre;
}

<div class="container mt-5 pt-5 mb-5">
    <div class="row align-items-center">
        
        <div class="col-md-6 text-center mb-4 mb-md-0">
            <img src="https://images.unsplash.com/photo-1593095191071-82b63de74e17?w=600" class="img-fluid rounded shadow-lg" alt="@Model.Nombre" style="max-height: 500px; object-fit: contain;">
        </div>

        <div class="col-md-6">
            <h5 class="text-secondary text-uppercase tracking-wider">@Model.Marca</h5>
            <h1 class="fw-black italic text-uppercase mb-3">@Model.Nombre</h1>
            
            <h2 class="text-danger fw-bold mb-4">
                $@Model.Precio.ToString("N2")
            </h2>

            <div class="mb-4">
                <span class="fw-bold">SABOR DISPONIBLE:</span>
                <div class="mt-2">
                    <span class="badge bg-dark border border-secondary p-2 fs-6">@Model.Sabor</span>
                </div>
            </div>

            @if (Model.Stock > 0)
            {
                <p class="text-success small fw-bold"><i class="bi bi-check-circle-fill"></i> Disponible (@Model.Stock en bodega)</p>
                <form action="#" method="post">
                    <input type="hidden" name="productoId" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger btn-lg rounded-0 w-100 fw-bold py-3 text-uppercase shadow">
                        <i class="bi bi-cart-plus"></i> AGREGAR AL CARRITO
                    </button>
                </form>
            }
            else
            {
                <p class="text-danger small fw-bold"><i class="bi bi-x-circle-fill"></i> Agotado temporalmente</p>
                <button class="btn btn-secondary btn-lg rounded-0 w-100 fw-bold py-3 text-uppercase shadow" disabled>
                    AGOTADO
                </button>
            }

            <hr class="my-4 border-secondary opacity-25">
            <p class="text-muted small">
                <i class="bi bi-truck"></i> Envío gratis a todo México en compras mayores a $999 MXN.
            </p>
        </div>
    </div>
</div>