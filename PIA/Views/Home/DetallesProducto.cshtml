<div class="container mt-5 pt-5 text-white">
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="main-image-container border border-secondary p-3 mb-3 bg-white shadow-sm">
                <img src="https://via.placeholder.com/500x500" id="mainImg" class="img-fluid" alt="Producto">
            </div>
            <div class="d-flex gap-2 justify-content-center">
                <img src="https://via.placeholder.com/100" class="img-thumbnail thumb" onclick="changeImg(this.src)" style="cursor:pointer">
                <img src="https://via.placeholder.com/100/ff0000" class="img-thumbnail thumb" onclick="changeImg(this.src)" style="cursor:pointer">
                <img src="https://via.placeholder.com/100/0000ff" class="img-thumbnail thumb" onclick="changeImg(this.src)" style="cursor:pointer">
            </div>
        </div>

        <div class="col-md-6">
            <h1 class="fw-bold italic text-uppercase">@ViewBag.NombreProducto</h1>
            <p class="text-danger fs-3 fw-bold">$1,299.00</p>
            <hr class="border-secondary">

            <div class="mb-4">
                <label class="fw-bold mb-2">SELECCIONA TU SABOR:</label>
                <select class="form-select bg-dark text-white border-secondary rounded-0">
                    <option>Chocolate Suizo</option>
                    <option>Vainilla Francesa</option>
                    <option>Fresa Silvestre</option>
                    <option>Cookies & Cream</option>
                </select>
            </div>

            <div class="mb-4">
                <h6 class="fw-bold">INFORMACIÓN DEL PRODUCTO:</h6>
                <p class="text-muted small">
                    Esta proteína de suero de leche de alta calidad proporciona 24g de proteína pura por porción.
                    Ideal para la recuperación muscular post-entrenamiento y el crecimiento de masa magra.
                    Baja en carbohidratos y grasas.
                </p>
                <ul class="text-muted small">
                    <li>5.5g de BCAAs naturales.</li>
                    <li>4g de Glutamina y ácido glutámico.</li>
                    <li>Libre de sustancias prohibidas.</li>
                </ul>
            </div>

            <div class="d-grid gap-3">
                <button class="btn btn-danger btn-lg rounded-0 fw-bold py-3">
                    <i class="bi bi-cart-plus"></i> AGREGAR AL CARRITO
                </button>

                <div class="text-center">
                    <a asp-action="PagoDirecto" class="text-white-50 text-decoration-underline small fw-light py-2 d-block">
                        Otras opciones de pago y finalizar compra
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function changeImg(src) {
        document.getElementById('mainImg').src = src;
    }
</script>
