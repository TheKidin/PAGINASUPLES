@model IEnumerable<PIA.Models.Producto>

@{
    ViewData["Title"] = "Inicio";
}

<section class="hero-section position-relative overflow-hidden text-center text-white">
    <div class="hero-overlay d-flex align-items-center justify-content-center">
        <div class="container hero-content">
            <h1 class="display-3 fw-black italic text-uppercase" style="letter-spacing: 2px;">Suplementos UANL</h1>
            <p class="lead fw-bold text-uppercase mt-2" style="letter-spacing: 2px; color: var(--text-muted); font-size: 0.9rem;">
                Alto rendimiento. Precisión clínica.
            </p>
            <a asp-controller="Home" asp-action="Catalogo" class="btn btn-danger btn-lg rounded-0 fw-bold px-5 mt-4 text-uppercase" style="letter-spacing: 2px;">
                EXPLORAR ARSENAL
            </a>
        </div>
    </div>
</section>

<div class="container mt-5 pt-4">

    <div class="text-center mb-5">
        <h3 class="fw-bold text-uppercase italic section-title">Más Vendidos</h3>
        <div class="underline mx-auto"></div>
    </div>

    <div class="row g-2 mb-4">
        <div class="col-6 col-md-3">
            <a asp-action="Proteinas" class="category-card-mini">
                <img src="~/imagenes/gold-standard-whey.jpg" class="img-fluid" alt="Proteinas">
                    <div class="mini-overlay"><span class="mini-text">Proteínas</span></div>
                </a>
            </div>

            <div class="col-6 col-md-3">
                <a asp-action="Aminoacidos" class="category-card-mini">
                    <img src="~/imagenes/aminopia.png" class="img-fluid" alt="Aminoacidos">
                        <div class="mini-overlay"><span class="mini-text">Aminoácidos</span></div>
                    </a>
                </div>
        
                <div class="col-6 col-md-3">
                    <a asp-action="Creatinas" class="category-card-mini">
                        <img src="~/imagenes/creatinaDragon200.png" class="img-fluid" alt="Creatinas">
                            <div class="mini-overlay"><span class="mini-text">Creatinas</span></div>
                        </a>
                    </div>

                    <div class="col-6 col-md-3">
                        <a asp-action="PreWorkouts" class="category-card-mini">
                            <img src="~/imagenes/prefresaK.png" class="img-fluid" alt="Pre-entreno">
                                <div class="mini-overlay"><span class="mini-text">Pre-Workouts</span></div>
                            </a>
                        </div>
                    </div>

                    <div class="text-center mb-5 mt-4">
                        <a asp-action="Catalogo" class="btn btn-dark rounded-0 px-4 fw-bold btn-sm text-uppercase" style="letter-spacing: 1px;">VER TODOS</a>
                    </div>

                    <hr class="my-5" style="border-color: var(--border-color);">

                    <div class="text-center mb-5">
                        <h3 class="fw-bold text-uppercase italic section-title">Nuevos Lanzamientos</h3>
                        <div class="underline mx-auto"></div>
                    </div>

                    <div class="row row-cols-2 row-cols-md-4 g-4 mb-5">
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <div class="col">
                                    <a asp-controller="Home" asp-action="Detalle" asp-route-id="@item.Id" class="text-decoration-none">
                                        <div class="card h-100 border-0 shadow-sm product-card">
                            
                                            <img src="https://images.unsplash.com/photo-1593095191071-82b63de74e17?w=300" class="card-img-top p-3" alt="@item.Nombre">
                            
                                            <div class="card-body text-center">
                                                <h6 class="card-title fw-bold small mb-1 text-uppercase" style="color: var(--text-main);">@item.Nombre</h6>
                                                <p class="text-danger fw-bold mb-3">$@item.Precio.ToString("N2")</p>
                                
                                                <span class="btn btn-buy btn-sm rounded-0 w-100 fw-bold text-uppercase">VER DETALLE</span>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            }
                        }
                    </div>

                    <div class="text-center mt-5 mb-5">
                        <a asp-action="Nuevo" class="btn btn-dark rounded-0 px-4 fw-bold btn-sm text-uppercase" style="letter-spacing: 1px;">Todos los Lanzamientos</a>
                    </div>
                </div>