@{
    ViewData["Title"] = "Novedades";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-uppercase italic">Recién Llegados ⚡</h2>
        <hr class="underline mx-auto">
    </div>

    <div class="d-flex justify-content-center gap-2 mb-5">
        <span class="badge bg-dark rounded-0 p-2">TODO LO NUEVO</span>
    </div>

    <div class="row row-cols-1 row-cols-md-4 g-4">
        <div class="col">
            <div class="card h-100 border-0 shadow-sm product-card">
                <div class="position-absolute p-2">
                    <span class="badge bg-danger text-uppercase">Nuevo</span>
                </div>
                <img src="https://via.placeholder.com/300" class="card-img-top p-4" alt="Nuevo Suplemento">
                <div class="card-body text-center">
                    <h5 class="fw-bold mb-1">ISO 100 HIDROLIZADA</h5>
                    <p class="small text-secondary mb-2">Dymatize Nutrition</p>
                    <h5 class="text-danger fw-bold">$1,450.00</h5>
                    <button class="btn btn-black-gym w-100 mt-2">VER DETALLES</button>
                </div>
            </div>
        </div>
    </div>
</div>
