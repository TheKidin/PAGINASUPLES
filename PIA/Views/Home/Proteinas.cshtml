@model IEnumerable<PIA.Models.Producto>

@{
    ViewData["Title"] = "Proteínas";
    
    // Recuperamos los filtros que el servidor nos mandó de regreso (para mantenerlos marcados)
    var tiposSeleccionados = ViewBag.TiposSeleccionados as List<string> ?? new List<string>();
    var marcaSeleccionada = ViewBag.MarcaSeleccionada as string ?? "";
}

<div class="container mt-4 mb-5">
    
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none hover-danger">Inicio</a></li>
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Catalogo" class="text-muted text-decoration-none hover-danger">Productos</a></li>
            <li class="breadcrumb-item active fw-bold" style="color: var(--accent-color);" aria-current="page">Proteínas</li>
        </ol>
    </nav>

    <div class="row">
        
        <div class="col-lg-3 mb-4 mb-lg-0">
            <form method="get" asp-controller="Home" asp-action="Proteinas" class="card p-4 rounded-0" style="background-color: var(--surface-dark); border: 1px solid var(--border-color);">
                <h5 class="fw-black text-white text-uppercase mb-4" style="letter-spacing: 1px;">Filtros</h5>

                <div class="mb-4">
                    <h6 class="text-white fw-bold text-uppercase mb-3" style="font-size: 0.85rem; letter-spacing: 1px;">TIPO DE PROTEÍNA</h6>
                    
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="tipos" value="Whey Protein" id="whey"
                        @(tiposSeleccionados.Contains("Whey Protein") ? "checked" : "")>
                        <label class="form-check-label text-white" for="whey" style="font-size: 0.85rem;">
                            Whey Protein
                        </label>
                    </div>
                    
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="tipos" value="Isolatada" id="isopure"
                        @(tiposSeleccionados.Contains("Isolatada") ? "checked" : "")>
                        <label class="form-check-label text-white" for="isopure" style="font-size: 0.85rem;">
                            Isolatada (Isolate)
                        </label>
                    </div>
                    
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="tipos" value="Vegana" id="vegan"
                        @(tiposSeleccionados.Contains("Vegana") ? "checked" : "")>
                        <label class="form-check-label text-white" for="vegan" style="font-size: 0.85rem;">
                            Vegana
                        </label>
                    </div>
                </div>

                <div class="mb-4">
                    <h6 class="text-white fw-bold text-uppercase mb-3" style="font-size: 0.85rem; letter-spacing: 1px;">MARCA</h6>
                    <select name="marca" class="form-select text-white rounded-0" style="background-color: var(--main-black); border: 1px solid var(--border-color); font-size: 0.85rem;">
                        <option value="" selected="@(string.IsNullOrEmpty(marcaSeleccionada))">Todas las marcas</option>
                        
                        <option value="Optimun Nutrition" selected="@(marcaSeleccionada == "Optimun Nutrition")">Optimun Nutrition</option>
                        <option value="Dymatize" selected="@(marcaSeleccionada == "Dymatize")">Dymatize</option>
                        <option value="Muscletech" selected="@(marcaSeleccionada == "Muscletech")">Muscletech</option>
                        <option value="Birdman" selected="@(marcaSeleccionada == "Birdman")">Birdman</option>
                        <option value="BPI Sports" selected="@(marcaSeleccionada == "BPI Sports")">BPI Sports</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-danger w-100 rounded-0 fw-bold text-uppercase py-2 mt-2" style="letter-spacing: 1px;">
                    Aplicar Filtros
                </button>
            </form>
        </div>

        <div class="col-lg-9">
            
            <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-2" style="border-color: var(--border-color) !important;">
                <h2 class="fw-black text-white text-uppercase italic mb-0" style="letter-spacing: 1px; font-size: 2rem;">PROTEÍNAS</h2>
                
                @if (tiposSeleccionados.Any() || !string.IsNullOrEmpty(marcaSeleccionada))
                {
                    <div>
                        <a asp-action="Proteinas" class="text-danger small text-decoration-none me-3"><i class="bi bi-x-circle me-1"></i>Limpiar Filtros</a>
                        <span class="text-muted small">Mostrando @(Model?.Count() ?? 0) resultados</span>
                    </div>
                }
                else
                {
                    <span class="text-muted small">Mostrando @(Model?.Count() ?? 0) productos</span>
                }
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                    
                    @foreach (var item in Model)
                    {
                        <div class="col">
                            <div class="card h-100 product-card rounded-0" style="background-color: var(--surface-dark); border: 1px solid var(--border-color);">
                                
                                <a asp-controller="Home" asp-action="Detalle" asp-route-id="@item.Id" class="text-decoration-none">
                                    <div class="p-3 d-flex align-items-center justify-content-center border-bottom" style="height: 250px; background-color: #000000; border-color: var(--border-color) !important;">
                                        <img src="@(string.IsNullOrEmpty(item.ImagenUrl) ? "https://images.unsplash.com/photo-1593095191071-82b63de74e17?w=600" : item.ImagenUrl)"
                                             class="img-fluid"
                                             alt="@item.Nombre"
                                             style="max-height: 100%; object-fit: contain;">
                                    </div>
                                </a>

                                <div class="card-body text-center p-4 d-flex flex-column">
                                    <span class="fw-bold text-uppercase d-block mb-2" style="color: var(--text-muted); font-size: 0.75rem; letter-spacing: 2px;">
                                        @item.Marca
                                    </span>
                                    
                                    <a asp-controller="Home" asp-action="Detalle" asp-route-id="@item.Id" class="text-decoration-none text-white title-hover">
                                        <h6 class="fw-black text-uppercase mb-3" style="letter-spacing: 1px; line-height: 1.4;">
                                            @item.Nombre
                                        </h6>
                                    </a>

                                    <div class="text-warning mb-3" style="font-size: 0.85rem;">
                                        <i class="bi bi-star-fill"></i>
                                        <i class="bi bi-star-fill"></i>
                                        <i class="bi bi-star-fill"></i>
                                        <i class="bi bi-star-fill"></i>
                                        <i class="bi bi-star-half"></i>
                                    </div>

                                    <div class="mt-auto">
                                        <span class="fw-black fs-5" style="color: var(--accent-color);">$@item.Precio.ToString("N2")</span>
                                    </div>
                                </div>
                                
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 mt-4" style="background-color: var(--surface-dark); border: 1px solid var(--border-color);">
                    <i class="bi bi-x-octagon text-muted mb-3" style="font-size: 3rem;"></i>
                    <h4 class="text-white text-uppercase fw-bold italic">Sin resultados</h4>
                    <p class="text-muted">No encontramos armamento que coincida con esos filtros.</p>
                    <a asp-action="Proteinas" class="btn btn-danger mt-3 rounded-0 text-uppercase fw-bold">Limpiar Búsqueda</a>
                </div>
            }

        </div>
    </div>
</div>