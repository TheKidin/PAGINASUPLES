@model IEnumerable<PIA.Models.Pedido>

@{
    ViewData["Title"] = "Centro de Mando - Pedidos";
}

<div class="container mt-5 pt-4 mb-5">
    <div class="text-center mb-5">
        <h2 class="fw-black text-uppercase italic text-white" style="letter-spacing: 2px;">GESTIÓN GLOBAL DE PEDIDOS</h2>
        <p class="text-danger fw-bold small text-uppercase">MODO ADMINISTRADOR: CONTROL TOTAL DEL ARSENAL</p>
    </div>

    <div class="card p-0 rounded-0" style="background-color: var(--surface-dark); border: 1px solid var(--border-color);">
        
        @* 🚀 ENCABEZADO REDISTRIBUIDO: 1 + 2 + 2 + 2 + 2 + 3 = 12 columnas *@
        <div class="d-none d-lg-flex row mx-0 p-3 text-uppercase small text-muted fw-bold align-items-center" style="border-bottom: 2px solid #333; background-color: #0a0a0a;">
            <div class="col-lg-1 ps-4">Orden</div>
            <div class="col-lg-2">Soldado (Email)</div>
            <div class="col-lg-2">Fecha</div>
            <div class="col-lg-2">Total</div>
            <div class="col-lg-2 text-center">Estatus</div>
            <div class="col-lg-3 text-center">Actualizar Radar</div>
        </div>

        @* CUERPO DE PEDIDOS *@
        <div>
            @if (Model != null && Model.Any())
            {
                @foreach (var p in Model)
                {
                    <div style="border-bottom: 1px solid #222;">
                        
                        <div class="row mx-0 py-3 align-items-center">
                            
                            @* Orden *@
                            <div class="col-6 col-lg-1 mb-2 mb-lg-0 ps-lg-4">
                                <span class="d-lg-none text-muted small d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Orden</span>
                                <span class="fw-bold text-white">#@p.Id.ToString("D4")</span>
                            </div>

                            @* Email (Soldado) - Reducido a 2 espacios *@
                            <div class="col-6 col-lg-2 mb-2 mb-lg-0 text-end text-lg-start">
                                <span class="d-lg-none text-muted small d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Soldado</span>
                                <span class="small text-truncate d-inline-block text-white" style="max-width: 100%;" title="@p.UsuarioId">@p.UsuarioId</span>
                            </div>

                            @* Fecha *@
                            <div class="col-6 col-lg-2 mb-2 mb-lg-0">
                                <span class="d-lg-none text-muted small d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Fecha</span>
                                <span class="text-white small">@p.FechaCompra.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>

                            @* 🚀 Total - Aumentado a 2 espacios y con text-nowrap *@
                            <div class="col-6 col-lg-2 mb-2 mb-lg-0 text-end text-lg-start">
                                <span class="d-lg-none text-muted small d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Total</span>
                                <span class="text-danger fw-bold text-nowrap">$@p.Total.ToString("N2")</span>
                            </div>

                            @* 🚀 Estatus - Etiqueta ajustada (text-wrap para que se vea bien si es muy largo) *@
                            <div class="col-12 col-lg-2 mb-3 mb-lg-0 text-center mt-2 mt-lg-0">
                                <span class="badge @(p.Estatus == "Entregado" ? "bg-success" : p.Estatus == "Cancelado" ? "bg-danger" : "bg-warning text-dark") rounded-0 text-uppercase w-100 w-lg-auto py-2 py-lg-1 text-wrap lh-sm" style="font-size: 0.65rem; letter-spacing: 1px;">
                                    @p.Estatus
                                </span>
                            </div>

                            @* Acciones (Botón Ojo y Formulario) *@
                            <div class="col-12 col-lg-3 mt-1 mt-lg-0 border-top border-secondary pt-3 pt-lg-0 border-lg-0">
                                <div class="d-flex gap-2 align-items-center justify-content-center justify-content-lg-end pe-lg-3">
                                    
                                    <button class="btn btn-sm btn-outline-light rounded-0 flex-shrink-0" type="button" data-bs-toggle="collapse" data-bs-target="#admin-mision-@p.Id" aria-expanded="false">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    
                                    @if (p.Estatus == "Entregado" || p.Estatus == "Cancelado")
                                    {
                                        <span class="badge bg-dark border border-secondary text-secondary px-3 py-2 rounded-0 w-100 w-lg-auto text-center" style="font-size: 0.7rem; letter-spacing: 1px;">
                                            <i class="bi bi-lock-fill"></i> CERRADO
                                        </span>
                                    }
                                    else
                                    {
                                        <form asp-action="ActualizarEstatus" method="post" class="d-flex gap-1 mb-0 w-100">
                                            <input type="hidden" name="id" value="@p.Id" />
                                            <select name="nuevoEstatus" class="form-select form-select-sm rounded-0 bg-black text-white border-secondary flex-grow-1" style="font-size: 0.75rem;">
                                                <option value="Pagado y Preparando">Preparando</option>
                                                <option value="Enviado">Enviado</option>
                                                <option value="Entregado">Entregado</option>
                                                <option value="Cancelado">Cancelado</option>
                                            </select>
                                            <button type="submit" class="btn btn-danger btn-sm rounded-0 flex-shrink-0">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>

                        </div>

                        @* 👁️ DETALLES OCULTOS *@
                        <div class="collapse" id="admin-mision-@p.Id">
                            <div class="p-3 p-md-4" style="background-color: #0a0a0a; border-top: 1px solid #222; border-bottom: 2px solid var(--accent-color);">
                                
                                <div class="row">
                                    <div class="col-md-6 mb-4 mb-md-0">
                                        <h6 class="text-danger fw-bold mb-3 text-uppercase" style="letter-spacing: 1px;">
                                            <i class="bi bi-geo-alt-fill me-2"></i> Coordenadas
                                        </h6>
                                        <div class="p-3" style="background-color: #141414; border: 1px solid #333;">
                                            <p class="mb-2 text-white small text-uppercase"><strong>Dirección:</strong> <br> <span class="text-muted">@p.Direccion</span></p>
                                            <p class="mb-0 text-white small text-uppercase"><strong>Ciudad/Estado:</strong> <br> <span class="text-muted">@p.Ciudad</span></p>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <h6 class="text-warning fw-bold mb-3 text-uppercase" style="letter-spacing: 1px;">
                                            <i class="bi bi-box-seam me-2"></i> Manifiesto de Carga
                                        </h6>
                                        <div class="d-flex flex-column gap-3">
                                            @if (p.Detalles != null)
                                            {
                                                @foreach (var detalle in p.Detalles)
                                                {
                                                    <div class="d-flex align-items-center p-2 p-md-3" style="background-color: #141414; border: 1px solid #333;">
                                                        <div style="width: 70px; height: 70px; background-color: #000;" class="d-flex justify-content-center align-items-center p-1 me-3 border border-secondary flex-shrink-0">
                                                            <img src="@(detalle.Variante?.Producto?.ImagenUrl ?? "https://dummyimage.com/200x200/cccccc/000000.png&text=Sin+Imagen")" class="img-fluid" style="object-fit: contain; max-height: 100%;" />
                                                        </div>
                                                        <div>
                                                            <h6 class="mb-1 text-white fw-bold text-uppercase lh-sm" style="letter-spacing: 1px; font-size: 0.85rem;">
                                                                <span class="text-danger fs-6 me-1">@detalle.Cantidad x</span> @(detalle.Variante?.Producto?.Nombre ?? "Desconocido")
                                                            </h6>
                                                            <span class="text-muted d-block mb-1" style="font-size: 0.75rem;">Sabor: @(detalle.Variante?.Sabor ?? "N/A")</span>
                                                            <span class="text-white fw-bold d-block" style="font-size: 0.9rem;">$@detalle.Precio.ToString("N2") <small class="text-muted fw-normal">c/u</small></span>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>

                    </div>
                }
            }
            else
            {
                <div class="p-5 text-center">
                    <i class="bi bi-radar text-muted mb-3 d-block" style="font-size: 3rem;"></i>
                    <h5 class="text-muted text-uppercase fw-bold" style="letter-spacing: 2px;">No hay pedidos registrados</h5>
                </div>
            }
        </div>
    </div>
</div>