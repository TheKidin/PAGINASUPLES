@model PIA.Models.Pedido
@{
    ViewData["Title"] = "Detalle de Misión #" + Model.Id;
}
<div class="container mt-5 pt-4">
    <h2 class="fw-black text-uppercase italic" style="color: var(--text-main);">Reporte de Misión #@Model.Id</h2>
    <div class="p-4 mt-4" style="border: 1px solid var(--border-color); background-color: var(--surface-dark);">
        <p class="text-muted text-uppercase small fw-bold">Resumen Táctico</p>
        <hr style="border-color: #333;">
        <div class="d-flex justify-content-between mb-2">
            <span>Fecha:</span> <span class="text-white">@Model.Fecha.ToString("f")</span>
        </div>
        <div class="d-flex justify-content-between mb-4">
            <span>Status:</span> <span class="text-danger fw-bold">@Model.Estado</span>
        </div>
        <h4 class="text-end fw-black text-danger">TOTAL: $@Model.Total.ToString("N2")</h4>
    </div>
    <a asp-action="Index" class="btn btn-outline-light rounded-0 mt-4 text-uppercase fw-bold">Volver al historial</a>
</div>