@model PIA.Models.Pedido

@{
    ViewData["Title"] = "Reporte de Misión";
}

<div class="container mt-5 pt-4 mb-5">
    <h2 class="fw-black text-uppercase italic text-white mb-4" style="border-bottom: 2px solid var(--accent-color); padding-bottom: 10px;">
        REPORTE DE MISIÓN #@Model.Id
    </h2>

    <div class="card bg-dark border-0 shadow-lg mb-4" style="background-color: var(--surface-dark) !important; border: 1px solid var(--border-color) !important;">
        <div class="card-header border-bottom border-secondary p-3">
            <h6 class="text-uppercase fw-bold text-muted mb-0" style="letter-spacing: 1px;">RESUMEN TÁCTICO</h6>
        </div>
        <div class="card-body p-4">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted text-uppercase fw-bold" style="font-size: 0.85rem; letter-spacing: 1px;">Fecha de despliegue:</span>
                <span class="text-white fw-bold">@Model.Fecha.ToString("dd MMM, yyyy - HH:mm")</span>
            </div>
            <div class="d-flex justify-content-between mb-4 pb-3" style="border-bottom: 1px solid #333;">
                <span class="text-muted text-uppercase fw-bold" style="font-size: 0.85rem; letter-spacing: 1px;">Status actual:</span>
                <span class="badge bg-warning text-dark fw-bold px-3 py-2 text-uppercase" style="font-size: 0.75rem; letter-spacing: 2px;">@Model.Estado</span>
            </div>

            <!-- ========================================== -->
            <!-- ARSENAL ADQUIRIDO (PRODUCTOS Y FOTOS)      -->
            <!-- ========================================== -->
            <h6 class="text-uppercase fw-bold text-white mb-3 mt-4" style="letter-spacing: 1px;">
                <i class="bi bi-box-seam me-2 text-danger"></i> ARSENAL ADQUIRIDO
            </h6>

            @if (Model.Detalles != null && Model.Detalles.Any())
            {
                <div class="list-group list-group-flush border-bottom border-secondary mb-4">
                    @foreach (var detalle in Model.Detalles)
                    {
                        // 🛠️ NOTA: Si en tu base de datos el producto no está dentro de "Variante",
                        // ajusta estas líneas (ejemplo: detalle.Producto?.Nombre)
                        var nombreProducto = detalle.Variante?.Producto?.Nombre ?? "Suplemento Clasificado";
                        var imagenUrl = detalle.Variante?.Producto?.ImagenUrl ?? "";
                        var sabor = detalle.Variante?.Sabor ?? "N/A";
                        var precioUnitario = detalle.Precio;
                        var cantidad = detalle.Cantidad;
                        var subtotal = precioUnitario * cantidad;

                        <div class="list-group-item bg-transparent border-0 px-0 py-3" style="border-bottom: 1px solid #222 !important;">
                            <div class="row align-items-center">
                                <!-- Foto del Producto -->
                                <div class="col-3 col-md-2 text-center">
                                    @if (!string.IsNullOrEmpty(imagenUrl))
                                    {
                                        <img src="@imagenUrl" alt="@nombreProducto" class="img-fluid rounded" style="max-height: 80px; object-fit: contain;">
                                    }
                                    else
                                    {
                                        <div class="bg-black d-flex justify-content-center align-items-center rounded" style="height: 80px; width: 100%;">
                                            <i class="bi bi-image text-secondary fs-3"></i>
                                        </div>
                                    }
                                </div>
                                
                                <!-- Info del Producto -->
                                <div class="col-9 col-md-6">
                                    <h6 class="text-white fw-bold mb-1 text-uppercase">@nombreProducto</h6>
                                    <small class="text-muted text-uppercase d-block mb-1" style="letter-spacing: 1px; font-size: 0.7rem;">SABOR: @sabor</small>
                                    <small class="text-white fw-bold" style="font-size: 0.8rem;">CANTIDAD: @cantidad  <span class="text-muted ms-2">(x @precioUnitario.ToString("C"))</span></small>
                                </div>
                                
                                <!-- Subtotal -->
                                <div class="col-12 col-md-4 text-md-end mt-3 mt-md-0">
                                    <span class="text-danger fw-black d-block fs-5">@subtotal.ToString("C")</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert bg-black border border-secondary text-muted text-center p-4 my-4 rounded-0">
                    <i class="bi bi-radar d-block mb-2 fs-2"></i>
                    No se encontraron registros detallados del armamento en esta orden.
                </div>
            }

            <div class="text-end mt-4">
                <span class="text-muted text-uppercase me-3" style="letter-spacing: 1px; font-size: 0.8rem;">Costo Total Operación:</span>
                <h3 class="text-danger fw-black d-inline-block m-0">@Model.Total.ToString("C")</h3>
            </div>
        </div>
    </div>

    <a asp-action="Index" class="btn btn-outline-light rounded-0 fw-bold text-uppercase px-4" style="letter-spacing: 1px;">
        <i class="bi bi-arrow-left me-2"></i> VOLVER AL HISTORIAL
    </a>
</div>