@model PIA.Models.Pedido

@{
    ViewData["Title"] = "Misión Completada";
}

<div class="container mt-5 mb-5 pt-5 text-center">
    <div class="card p-5 rounded-0 mx-auto" style="max-width: 600px; background-color: var(--surface-dark); border: 1px solid var(--border-color);">
        
        <i class="bi bi-check-circle-fill text-success mb-4" style="font-size: 5rem;"></i>
        
        <h1 class="fw-black text-white text-uppercase italic mb-3" style="letter-spacing: 2px;">¡MISIÓN COMPLETADA!</h1>
        <div class="underline mx-auto border-success mb-4" style="width: 50px; border-top: 3px solid;"></div>
        
        <p class="text-muted fs-5 mb-4">
            Tu pago ha sido procesado de manera segura en la bóveda de **Stripe**. Nuestro equipo logístico ya está preparando tu arsenal para la extracción.
        </p>

        <div class="bg-black p-4 mb-4 border border-secondary text-start">
            <h6 class="text-uppercase text-danger fw-bold mb-3" style="letter-spacing: 1px;">
                <i class="bi bi-receipt me-2"></i> Detalles de la Operación
            </h6>
            
            <div class="d-flex justify-content-between text-white mb-2">
                <span class="text-muted small">Número de Orden:</span>
                <span class="fw-bold">#@Model.Id.ToString("D4")</span>
            </div>
            
            <div class="d-flex justify-content-between text-white mb-2">
                <span class="text-muted small">Fecha de Autorización:</span>
                <span class="fw-bold">@Model.FechaCompra.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            
            <div class="d-flex justify-content-between text-white border-top border-secondary pt-2 mt-2">
                <span class="text-uppercase fw-bold small">Total Invertido:</span>
                <span class="fw-black text-success fs-5">$@Model.Total.ToString("N2") <small>MXN</small></span>
            </div>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-center gap-3">
            <a asp-controller="Home" asp-action="Catalogo" class="btn btn-outline-light rounded-0 fw-bold text-uppercase px-4 py-2" style="letter-spacing: 1px;">
                <i class="bi bi-arrow-left me-2"></i> Volver al Catálogo
            </a>
            <a asp-controller="Pedidos" asp-action="Index" class="btn btn-danger rounded-0 fw-bold text-uppercase px-4 py-2" style="letter-spacing: 1px;">
                Ver mis pedidos <i class="bi bi-crosshair ms-2"></i>
            </a>
        </div>

        <p class="text-muted mt-4 mb-0" style="font-size: 0.75rem;">
            Se ha enviado un reporte detallado a tu correo electrónico registrado.
        </p>

    </div>
</div>