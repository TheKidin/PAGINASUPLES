@{
    ViewData["Title"] = "Nuevo Arsenal";
}

<div class="container mt-5 pt-4">
    <div class="text-center mb-5">
        <h2 class="fw-black text-uppercase italic section-title" style="letter-spacing: 2px; color: var(--text-main);">
            Nuevo Arsenal Táctico
        </h2>
        <div class="underline mx-auto mt-3"></div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="p-5" style="border: 1px solid var(--border-color); background-color: var(--surface-dark);">
                
                <h6 class="fw-bold text-uppercase mb-4" style="color: var(--text-muted); font-size: 0.7rem; letter-spacing: 2px;">Especificaciones Técnicas</h6>
                
                <form asp-action="Create">
                    @* Asegúrate de tener el tag helper de validación si tu compañero lo usó: <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div> *@
                    
                    <div class="mb-4">
                        <label class="form-label text-muted text-uppercase small fw-bold" style="letter-spacing: 2px;">Nombre</label>
                        <input class="form-control" placeholder="Ej. GOLD STANDARD WHEY" required />
                        @* <span asp-validation-for="Nombre" class="text-danger small"></span> *@
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted text-uppercase small fw-bold" style="letter-spacing: 2px;">Marca</label>
                        <input class="form-control" placeholder="Ej. Optimun Nutrition" required />
                        @* <span asp-validation-for="Marca" class="text-danger small"></span> *@
                    </div>

                    <div class="mb-5">
                        <label class="form-label text-muted text-uppercase small fw-bold" style="letter-spacing: 2px;">Precio (MXN)</label>
                        <input class="form-control" placeholder="Ej. 1299.00" required />
                        @* <span asp-validation-for="Precio" class="text-danger small"></span> *@
                    </div>

                    <button type="submit" class="btn btn-danger btn-lg rounded-0 w-100 fw-black py-3 text-uppercase btn-cart-premium" style="letter-spacing: 2px;">
                        <i class="bi bi-shield-check-fill me-2"></i> REGISTRAR ARMAMENTO
                    </button>
                </form>

                <div class="text-center mt-4 pt-3" style="border-top: 1px solid #333;">
                    <a asp-action="Index" class="text-muted small text-decoration-none text-uppercase hover-danger" style="letter-spacing: 1px;">
                        <i class="bi bi-arrow-left me-1"></i> Volver a Inventario
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>