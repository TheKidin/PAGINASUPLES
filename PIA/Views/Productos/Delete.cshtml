@model PIA.Models.Producto

@{
    ViewData["Title"] = "Confirmar Baja de Arsenal";
}

<div class="container mt-5 pt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <div class="card bg-black rounded-0" style="border: 1px solid #dc3545; box-shadow: 0 0 15px rgba(220, 53, 69, 0.2);">
                <div class="card-header bg-danger text-white text-center py-3 rounded-0 border-0">
                    <h4 class="fw-black text-uppercase italic mb-0" style="letter-spacing: 2px;">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> ADVERTENCIA TÁCTICA
                    </h4>
                </div>
                
                <div class="card-body p-4 p-md-5" style="background-color: var(--surface-dark);">
                    <p class="text-center text-white mb-4 fs-5 fw-bold">
                        ¿Estás seguro de que deseas dar de baja este armamento permanentemente?
                    </p>

                    <div class="p-4 mb-4" style="border: 1px solid #333; background-color: #0a0a0a;">
                        <div class="row mb-3 pb-2" style="border-bottom: 1px solid #222;">
                            <div class="col-5 text-muted text-uppercase fw-bold" style="font-size: 0.8rem; letter-spacing: 1px;">Nombre</div>
                            <div class="col-7 text-white fw-bold">@Html.DisplayFor(model => model.Nombre)</div>
                        </div>
                        <div class="row mb-3 pb-2" style="border-bottom: 1px solid #222;">
                            <div class="col-5 text-muted text-uppercase fw-bold" style="font-size: 0.8rem; letter-spacing: 1px;">Marca</div>
                            <div class="col-7 text-white">@Html.DisplayFor(model => model.Marca)</div>
                        </div>
                        <div class="row">
                            <div class="col-5 text-muted text-uppercase fw-bold" style="font-size: 0.8rem; letter-spacing: 1px;">Precio</div>
                            <div class="col-7 text-danger fw-black fs-5">$@Html.DisplayFor(model => model.Precio)</div>
                        </div>
                    </div>

                    <form asp-action="Delete" class="d-flex flex-column flex-md-row justify-content-between gap-3">
                        <input type="hidden" asp-for="Id" />
                        
                        <a asp-action="Index" class="btn btn-outline-light rounded-0 w-100 fw-bold text-uppercase py-2" style="letter-spacing: 1px;">
                            <i class="bi bi-arrow-left me-2"></i> Abortar Misión
                        </a>
                        
                        <button type="submit" class="btn btn-danger rounded-0 w-100 fw-bold text-uppercase py-2" style="letter-spacing: 1px;">
                            <i class="bi bi-trash3-fill me-2"></i> Confirmar Baja
                        </button>
                    </form>
                    
                </div>
            </div>
            
        </div>
    </div>
</div>