@model PIA.Models.VarianteProducto

@{
    ViewData["Title"] = "Editar Sabor";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 mx-auto">
            <h2 class="fw-bold text-uppercase mb-1">Editar Sabor</h2>
            <h5 class="text-muted mb-4">@Model.Producto?.Nombre</h5>

            <div class="card shadow-sm border-0 bg-light p-4">
                <form asp-action="EditarSabor">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ProductoId" />
                    
                    <div class="mb-3">
                        <label asp-for="Sabor" class="form-label fw-bold small">Nombre del Sabor</label>
                        <input asp-for="Sabor" class="form-control" required />
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Stock" class="form-label fw-bold small">Unidades en Stock (Bodega)</label>
                        <input asp-for="Stock" class="form-control" type="number" min="0" required />
                    </div>
                    
                    <div class="d-flex gap-2">
                        <a asp-action="Sabores" asp-route-id="@Model.ProductoId" class="btn btn-outline-secondary w-50 fw-bold">CANCELAR</a>
                        <button type="submit" class="btn btn-warning w-50 fw-bold text-dark">GUARDAR CAMBIOS</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>