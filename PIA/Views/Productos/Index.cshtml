@model IEnumerable<PIA.Models.Producto>

@{
    ViewData["Title"] = "Panel de Control";
}



<div class="container mt-5 mb-5 pt-3">
    
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center border-bottom border-secondary pb-3 mb-4">
        <h2 class="fw-black text-uppercase mb-3 mb-md-0 text-white" style="font-style: italic; letter-spacing: 1px;">
            Panel de Control: Productos
        </h2>
        <a asp-action="Create" class="btn btn-danger fw-bold px-4 py-2 rounded-pill shadow-sm" style="font-size: 0.9rem; letter-spacing: 1px;">
            <i class="bi bi-plus-lg me-2"></i> AÑADIR NUEVO ARSENAL
        </a>
    </div>

    <div class="card bg-transparent border-secondary shadow-lg rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                
                <div class="row mb-4 pt-3 px-3">
                    <div class="col-md-6 col-lg-4">
                        <div class="input-group" style="border: 1px solid var(--border-color);">
                            <span class="input-group-text border-0 rounded-0" style="background-color: #141414; color: var(--accent-color);">
                                <i class="bi bi-search text-danger"></i>
                            </span>
                            <input type="text" id="busquedaArsenal" class="form-control border-0 rounded-0 text-white"
                                   style="background-color: #141414; box-shadow: none;"
                                   placeholder="Buscar nombre, marca o precio...">
                        </div>
                    </div>
                </div>

                <table class="table table-dark table-hover align-middle mb-0 text-white">
                    <thead class="table-active border-bottom border-secondary">
                        <tr>
                            <th class="px-4 py-3 text-uppercase text-muted" style="font-size: 0.85rem; letter-spacing: 1px;">Nombre</th>
                            <th class="py-3 text-uppercase text-muted" style="font-size: 0.85rem; letter-spacing: 1px;">Marca</th>
                            <th class="py-3 text-uppercase text-muted" style="font-size: 0.85rem; letter-spacing: 1px;">Precio</th>
                            <th class="px-4 py-3 text-end text-uppercase text-muted" style="font-size: 0.85rem; letter-spacing: 1px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="border-bottom border-secondary" style="border-color: rgba(255,255,255,0.1) !important;">
                                <td class="px-4 py-3 fw-bold">@item.Nombre</td>
                                <td class="py-3" style="color: #adb5bd;">@item.Marca</td>
                                <td class="py-3 fw-bold text-white">$@item.Precio.ToString("N2")</td>
                                
                                <td class="px-4 py-3 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-pill px-3 fw-semibold" style="font-size: 0.8rem;">
                                            <i class="bi bi-pencil-square me-1"></i> Editar
                                        </a>
                                        
                                        <a asp-action="Sabores" asp-route-id="@item.Id" class="btn btn-sm btn-warning rounded-pill px-3 fw-bold text-dark" style="font-size: 0.8rem;">
                                            <i class="bi bi-tags-fill me-1"></i> Sabores
                                        </a>
                                        
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light rounded-pill px-3 fw-semibold" style="font-size: 0.8rem;">
                                            <i class="bi bi-eye me-1"></i> Detalles
                                        </a>
                                        
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger rounded-pill px-3 fw-semibold" style="font-size: 0.8rem;">
                                            <i class="bi bi-trash-fill me-1"></i> Borrar
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <p class="text-muted mb-0">No tienes productos registrados en tu arsenal.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Escuchamos cada vez que se teclea algo en el buscador
        document.getElementById('busquedaArsenal').addEventListener('keyup', function() {
            
            // Pasamos a minúsculas lo que escribiste para que la búsqueda sea exacta
            let textoBuscado = this.value.toLowerCase();
            
            // Seleccionamos todas las filas del cuerpo de la tabla
            let filas = document.querySelectorAll('table tbody tr');

            filas.forEach(function(fila) {
                // Obtenemos todo el texto que está dentro de esa fila (Nombre, Marca, Precio, etc.)
                let contenidoFila = fila.textContent.toLowerCase();
                
                // Si la fila contiene lo que buscamos, la dejamos visible. Si no, la ocultamos.
                if (contenidoFila.includes(textoBuscado)) {
                    fila.style.display = '';
                } else {
                    fila.style.display = 'none';
                }
            });
        });
    </script>
}