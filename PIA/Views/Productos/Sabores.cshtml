@model PIA.Models.Producto

@{
    ViewData["Title"] = "Sabores - " + Model.Nombre;
}

<div class="container mt-4">
    <h2 class="fw-bold text-uppercase">Administrar Sabores</h2>
    <h4 class="text-muted">@Model.Nombre (@Model.Marca)</h4>
    <hr />

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 bg-light p-3">
                <h5 class="fw-bold mb-3">➕ Nuevo Sabor</h5>
                
                <form asp-action="AgregarSabor" method="post">
                    <input type="hidden" name="productoId" value="@Model.Id" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Nombre del Sabor</label>
                        <input type="text" name="sabor" class="form-control" placeholder="Ej. Chocolate Mint" required />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Stock Inicial (Botes)</label>
                        <input type="number" name="stock" class="form-control" value="10" min="0" required />
                    </div>
                    
                    <button type="submit" class="btn btn-dark w-100 fw-bold">GUARDAR SABOR</button>
                </form>
            </div>
            
            <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-3">Volver a la lista</a>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0 p-3">
                <h5 class="fw-bold mb-3">📋 Sabores Registrados</h5>
                
                @if (Model.Variantes != null && Model.Variantes.Any())
                {
                    <table class="table table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Sabor</th>
                                <th>Stock Disponible</th>
                                <th>Estado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var variante in Model.Variantes)
                            {
                                <tr>
                                    <td class="fw-bold">@variante.Sabor</td>
                                    <td>@variante.Stock unidades</td>
                                    <td>
                                        @if (variante.Stock > 0)
                                        {
                                            <span class="badge bg-success">Disponible</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Agotado</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a asp-action="EditarSabor" asp-route-id="@variante.Id" class="btn btn-sm btn-warning fw-bold shadow-sm" title="Editar unidades o nombre">
                                                <i class="bi bi-pencil-square"></i> Editar
                                            </a>

                                            <form asp-action="EliminarSabor" method="post" onsubmit="return confirm('¡ALERTA 3312! 🚨 ¿Estás totalmente seguro de que deseas desintegrar el sabor @variante.Sabor?');">
                                                <input type="hidden" name="id" value="@variante.Id" />
                                                <input type="hidden" name="productoId" value="@Model.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger fw-bold shadow-sm" title="¡Eliminar sabor!">
                                                    <i class="bi bi-exclamation-triangle-fill"></i> 3312
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-warning text-center">
                        Aún no le has registrado ningún sabor a este producto. <br> Usa el formulario de la izquierda para agregar el primero.
                    </div>
                }
            </div>
        </div>
    </div>
</div>