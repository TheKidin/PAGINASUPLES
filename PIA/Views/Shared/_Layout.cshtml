@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SMUANL Performance</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/Tienda-Gym.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PIA.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div class="top-bar py-2" style="background-color: #050505; border-bottom: 1px solid var(--border-color);">
            <div class="container d-flex justify-content-between align-items-center">
                <small class="text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 2px; color: var(--text-muted);">
                    <span class="text-danger">⚡ STATUS:</span> ENVÍOS GRATIS EN COMPRAS MAYORES A $999
                </small>
                <div class="social-icons" style="font-size: 0.8rem;">
                    <a href="#" class="text-decoration-none ms-3"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="text-decoration-none ms-3"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="text-decoration-none ms-3"><i class="bi bi-tiktok"></i></a>
                </div>
            </div>
        </div>

        <nav class="navbar navbar-expand-lg navbar-dark bg-black py-3" style="border-bottom: 1px solid var(--border-color);">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center me-5" asp-controller="Home" asp-action="Index">
                    <span class="fs-4 fw-black italic text-white" style="letter-spacing: 1px;">SMUANL</span>
                    <span class="fs-4 fw-black italic text-danger ms-1" style="letter-spacing: 1px;">PERFORMANCE</span>
                </a>

                <button class="navbar-toggler rounded-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" style="border-color: var(--border-color);">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto text-uppercase fw-bold">
                        <li class="nav-item">
                            <a class="nav-link custom-link" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-link" asp-controller="Home" asp-action="Catalogo">Catálogo</a>
                        </li>

                        @if (SignInManager.IsSignedIn(User) && User.Identity?.Name == "SMUANL2026@hotmail.com")
                        {
                            <li class="nav-item">
                                <a class="nav-link custom-link text-danger" asp-controller="Productos" asp-action="Index" style="border-bottom: 2px solid var(--accent-color);">
                                    <i class="bi bi-gear-fill"></i> CONTROL
                                </a>
                            </li>
                            
                            <li class="nav-item ms-lg-3 mt-2 mt-lg-0 d-flex align-items-center">
                                <a class="nav-link position-relative text-warning custom-link" asp-controller="Productos" asp-action="StockBajo" style="transition: 0.3s;">
                                    <i class="bi bi-exclamation-triangle-fill me-1"></i> ALERTA STOCK
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.55rem; padding: 3px 5px;">
                                        !
                                    </span>
                                </a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-4 text-white">
                        <a href="#" class="text-white hover-danger" style="transition: 0.3s;"><i class="bi bi-search fs-5"></i></a>
                    
                        <div class="dropdown">
                            <a href="#" class="text-white text-decoration-none" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="transition: 0.3s;">
                                @if (SignInManager.IsSignedIn(User))
                                {
                                    <i class="bi bi-person-fill fs-4 text-danger"></i>
                                }
                                else
                                {
                                    <i class="bi bi-person fs-4 hover-danger"></i>
                                }
                            </a>
                        
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark mt-3 rounded-0" aria-labelledby="userDropdown" style="background-color: var(--surface-dark); border: 1px solid var(--border-color);">
                                @if (SignInManager.IsSignedIn(User))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index" style="font-size: 0.8rem; letter-spacing: 1px;">
                                            <i class="bi bi-person-badge me-2"></i> MI PERFIL
                                        </a>
                                    </li>
                                    
                                    <li>
                                        <a class="dropdown-item" asp-controller="Pedidos" asp-action="Index" style="font-size: 0.8rem; letter-spacing: 1px;">
                                            <i class="bi bi-box-seam me-2 text-warning"></i> MIS PEDIDOS
                                        </a>
                                    </li>

                                    <li><hr class="dropdown-divider" style="border-color: var(--border-color);"></li>
                                    <li>
                                        <form class="form-inline m-0 p-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                            <button type="submit" class="dropdown-item text-danger fw-bold" style="font-size: 0.8rem; letter-spacing: 1px;">
                                                <i class="bi bi-box-arrow-right me-2"></i> CERRAR SESIÓN
                                            </button>
                                        </form>
                                    </li>
                                }
                                else
                                {
                                    <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Login" style="font-size: 0.8rem; letter-spacing: 1px;"><i class="bi bi-box-arrow-in-right me-2"></i> INICIAR SESIÓN</a></li>
                                    <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Register" style="font-size: 0.8rem; letter-spacing: 1px;"><i class="bi bi-person-plus me-2"></i> CREAR CUENTA</a></li>
                                }
                            </ul>
                        </div>

                        <a href="#" class="text-white position-relative hover-danger" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas" aria-controls="cartOffcanvas" style="transition: 0.3s;">
                            <i class="bi bi-cart3 fs-5"></i>
                            <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge bg-danger rounded-0" style="font-size: 0.55rem; padding: 3px 5px; font-weight: 900; transition: transform 0.2s;">0</span>
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    
        <div class="offcanvas offcanvas-end rounded-0 tactical-side-cart" tabindex="-1" id="cartOffcanvas" aria-labelledby="cartOffcanvasLabel" style="border-left: 1px solid var(--border-color); background-color: var(--surface-dark); width: 400px; color: var(--text-main);">
        
            <div class="offcanvas-header pb-3" style="border-bottom: 1px solid var(--border-color);">
                <div class="d-flex align-items-center mt-2">
                    <i class="bi bi-backpack text-danger me-3 fs-5"></i>
                    <h6 class="offcanvas-title fw-black text-uppercase italic mb-0" id="cartOffcanvasLabel" style="letter-spacing: 2px;">TU ARSENAL LATERAL</h6>
                </div>
                <button type="button" class="btn-close btn-close-white rounded-0" data-bs-dismiss="offcanvas" aria-label="Close" style="font-size: 0.8rem; border: 1px solid #333;"></button>
            </div>
        
            <div class="offcanvas-body p-0" id="cartOffcanvasBody">
            
                @* Inicializamos con una vista parcial vacía *@
                @await Html.PartialAsync("_MiniCarrito", Enumerable.Empty<PIA.Models.ItemCarrito>())
            
            </div>
        
            <div class="offcanvas-footer p-4 pt-3" style="border-top: 1px solid var(--border-color); background-color: #0F0F0F;">
            
                <div id="cartFooterContent">
                    @* Inicializamos con un footer parcial vacío *@
                    @await Html.PartialAsync("_MiniCarritoFooter", Enumerable.Empty<PIA.Models.ItemCarrito>())
                </div>
            
            </div>
        </div>
        
    </header>

    <div class="container-fluid p-0">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-black text-white pt-5 pb-3 mt-5" style="border-top: 1px solid var(--border-color);">
        <div class="container">
            <div class="row text-center text-md-start">
                
                <div class="col-md-5 mb-4">
                    <h5 class="fw-black italic text-uppercase" style="letter-spacing: 2px;">SMUANL <span class="text-danger">PERFORMANCE</span></h5>
                    <p class="mt-3" style="color: var(--text-muted); font-size: 0.75rem; letter-spacing: 1px; max-width: 350px;">
                        DISEÑADO PARA ATLETAS QUE EXIGEN PRECISIÓN CLÍNICA Y RENDIMIENTO DE ALTA VELOCIDAD. NO ADIVINAMOS, NOSOTROS MEDIMOS.
                    </p>
                </div>
                
                <div class="col-md-3 mb-4 text-md-start text-center">
                    <h6 class="text-uppercase fw-bold text-danger" style="font-size: 0.7rem; letter-spacing: 2px;">NAVEGACIÓN</h6>
                    <ul class="list-unstyled mt-3">
                        <li class="mb-2"><a asp-action="Catalogo" class="text-decoration-none" style="color: var(--text-muted); font-size: 0.75rem; letter-spacing: 1px; transition: 0.3s;">VER CATÁLOGO</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: var(--text-muted); font-size: 0.75rem; letter-spacing: 1px; transition: 0.3s;">TÉRMINOS DE SERVICIO</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: var(--text-muted); font-size: 0.75rem; letter-spacing: 1px; transition: 0.3s;">POLÍTICA DE PRIVACIDAD</a></li>
                    </ul>
                </div>
                
                <div class="col-md-4 mb-4 text-md-start text-center">
                    <h6 class="text-uppercase fw-bold text-danger" style="font-size: 0.7rem; letter-spacing: 2px;">LOGÍSTICA</h6>
                    <ul class="list-unstyled mt-3">
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: var(--text-muted); font-size: 0.75rem; letter-spacing: 1px; transition: 0.3s;">INFORMACIÓN DE ENVÍO</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: var(--text-muted); font-size: 0.75rem; letter-spacing: 1px; transition: 0.3s;">DEVOLUCIONES Y GARANTÍAS</a></li>
                    </ul>
                </div>

            </div>
            
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-4 pt-4" style="border-top: 1px solid var(--border-color);">
                <p class="mb-2 mb-md-0" style="color: var(--text-muted); font-size: 0.65rem; letter-spacing: 1px; text-transform: uppercase;">
                    &copy; 2026 SMUANL. RENDIMIENTO DE ALTA VELOCIDAD.
                </p>
                <div class="social-icons fs-6">
                    <i class="bi bi-globe mx-2" style="color: var(--text-muted); cursor: pointer;"></i>
                    <i class="bi bi-instagram mx-2" style="color: var(--text-muted); cursor: pointer;"></i>
                    <i class="bi bi-shield-check mx-2" style="color: var(--text-muted); cursor: pointer;"></i>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>