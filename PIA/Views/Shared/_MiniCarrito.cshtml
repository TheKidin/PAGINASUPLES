    @using System.Linq
    @model IEnumerable<PIA.Models.ItemCarrito>

    @* Asegúrate de que el modelo coincida con el nombre exacto que usó tu compañero *@

    @if (Model != null && Model.Any())
    {
        @foreach (var item in Model)
        {
            // Extraemos datos básicos del producto
            decimal precioUnitario = item.Variante?.Producto?.Precio ?? 0;
        
            <div class="row align-items-center mb-0 p-3" style="border-bottom: 1px solid var(--border-color); background-color: var(--surface-dark);">
            
                <div class="col-4">
                    <div style="width: 100px; height: 100px; background-color: #111; border: 1px solid var(--border-color); position: relative;" class="d-flex justify-content-center align-items-center p-2">
                        @if (item.Variante?.Producto == null || string.IsNullOrEmpty(item.Variante.Producto.ImagenUrl))
                        {
                            <i class="bi bi-box-seam fs-2 text-secondary"></i>
                        }
                        else
                        {
                            <img src="@item.Variante.Producto.ImagenUrl" class="img-fluid rounded-0 border border-dark" alt="@item.Variante.Producto.Nombre" style="width: 80px; height: 80px; object-fit: cover;" />
                        }
                    </div>
                </div>
            
                <div class="col-8">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h6 class="mb-0 fw-bold text-uppercase" style="color: var(--text-main); letter-spacing: 1px; font-size: 0.8rem;">
                                @(item.Variante?.Producto?.Nombre ?? "Suplemento Desconocido")
                            </h6>
                            <small style="color: var(--text-muted); font-size: 0.7rem;">
                                Sabor: @(item.Variante?.Sabor ?? "N/A")
                            </small>
                        </div>
                        <button class="btn btn-link text-muted hover-danger p-0 ms-2 remove-item" data-id="@item.Id" title="Remover">
                            <i class="bi bi-trash3 fs-6"></i>
                        </button>
                    </div>
                
                    <div class="d-flex justify-content-between align-items-end mt-2">
                        <div class="d-flex flex-column align-items-center border border-secondary" style="width: 35px; border-radius: 2px;">
                        
                            <button class="btn btn-sm btn-dark w-100 p-0 rounded-0 btn-update-qty" data-id="@item.Id" data-op="1" style="border-bottom: 1px solid #333;">
                                <i class="bi bi-plus fs-7"></i>
                            </button>
                        
                            <span class="fw-bold fs-6 text-white py-1">@item.Cantidad</span>
                        
                            <button class="btn btn-sm btn-dark w-100 p-0 rounded-0 btn-update-qty" data-id="@item.Id" data-op="-1" style="border-top: 1px solid #333;">
                                <i class="bi bi-dash fs-7"></i>
                            </button>
                        
                        </div>
                    
                        <h6 class="text-danger fw-black mb-0" style="font-size: 1.1rem;">
                            $@precioUnitario.ToString("N2")
                        </h6>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-bag-x text-muted mb-3" style="font-size: 4rem;"></i>
            <h6 class="fw-bold text-uppercase text-muted" style="letter-spacing: 2px;">Arsenal Vacío</h6>
        </div>
    }