@using System.Linq
@model IEnumerable<PIA.Models.ItemCarrito>

@{
    decimal totalEstimado = Model != null ? Model.Sum(item => (item.Variante?.Producto?.Precio ?? 0) * item.Cantidad) : 0;
}

<div class="d-flex justify-content-between mb-2 text-uppercase fw-bold" style="color: var(--text-muted); letter-spacing: 1px; font-size: 0.75rem;">
    <span>Subtotal Estimado</span>
    <span class="text-white fw-black" style="font-size: 1rem;">
        $@totalEstimado.ToString("N2")
    </span>
</div>

<div class="text-uppercase" style="color: var(--text-muted); font-size: 0.65rem; letter-spacing: 1px; border-bottom: 1px solid #333; padding-bottom: 10px;">
    Cálculo final de envío e impuestos se procesará en el pago.
</div>

@* 🚀 CAMBIO TÁCTICO: Redirigimos al cuartel principal del carrito *@
@if (totalEstimado > 0)
{
    <a asp-controller="Carrito" asp-action="Index" class="btn btn-danger w-100 rounded-0 fw-bold text-uppercase py-3 d-flex justify-content-center align-items-center mt-3" style="letter-spacing: 2px;">
        <i class="bi bi-cart-check-fill me-2"></i> IR AL ARSENAL Y PAGAR
    </a>
}
else
{
    <button class="btn btn-secondary w-100 rounded-0 fw-bold text-uppercase py-3 d-flex justify-content-center align-items-center mt-3 disabled" style="letter-spacing: 2px;">
        <i class="bi bi-cart-x me-2"></i> ARSENAL VACÍO
    </button>
}